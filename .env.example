# Decifer Trading — Environment Variables Template
# Copy this to .env and fill in your keys.
# Never commit .env to version control.
#
# Usage: cp .env.example .env

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Market Data ────────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

FMP_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=

# ── Broker ─────────────────────────────────────────────────────────────────────
IBKR_ACTIVE_ACCOUNT=
IBKR_PAPER_ACCOUNT=

# ── Optional overrides ─────────────────────────────────────────────────────────
# DECIFER_REPO_PATH=/path/to/decifer-trading   # only needed if auto-detect fails
# PORT=8181
# REFRESH_INTERVAL_MS=30000
