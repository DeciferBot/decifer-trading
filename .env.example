# Decifer Trading — Environment Variables Template
# Copy this to .env and fill in real values. Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # fill in values, then:
#   python3 scripts/healthcheck.py
#
# Cloud deployments: inject these via a secrets manager (AWS SSM, GCP Secret Manager)
# rather than deploying a .env file directly. See docs/cloud_readiness_contract.md.
#
# Validation: run `python3 scripts/healthcheck.py` after populating.
# Required variables cause a blocking FAIL; recommended variables cause a warning.

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED — bot will not operate without these
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM / Apex synthesizer ────────────────────────────────────────────────────
# Claude API key for the Apex Single-Synthesizer (claude-sonnet-4-6).
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Market data — Alpaca Algo Trader Plus ($99/mo) ────────────────────────────
# Primary source for real-time quotes, options chains, and streaming data.
# Paper trading base URL shown below; change for live when approved.
# Get from: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Broker — IBKR account identifiers ────────────────────────────────────────
# Paper account: starts with DU (e.g. DUP481326)
# IBKR_ACTIVE_ACCOUNT must match the account the bot will trade on.
IBKR_ACTIVE_ACCOUNT=
IBKR_PAPER_ACCOUNT=

# ══════════════════════════════════════════════════════════════════════════════
# STRONGLY RECOMMENDED — degraded operation without these
# ══════════════════════════════════════════════════════════════════════════════

# ── Financial Modeling Prep (fundamentals, events, analyst actions) ───────────
# Used by catalyst_engine.py, fmp_client.py. Premium tier: 750 calls/min.
# Get from: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# ── Alpha Vantage (macro indicators, earnings calendar fallback) ──────────────
# Free tier: 25 calls/day. Paid: higher limits.
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ── FRED (Federal Reserve Economic Data) ─────────────────────────────────────
# Free, unlimited. Used by economic intelligence workers.
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# IBKR GATEWAY — connection parameters
# ══════════════════════════════════════════════════════════════════════════════

# IBKR Gateway host.
#   Local / Linux VM with host networking: leave unset → defaults to 127.0.0.1
#   macOS Docker Desktop: IBKR_HOST=host.docker.internal
#   Separate Gateway VM: IBKR_HOST=<private IP of Gateway VM>
# IBKR_HOST=127.0.0.1

# IBKR Gateway port.
#   IB Gateway paper : 4002   ← recommended for cloud
#   IB TWS paper     : 7497
#   IB Gateway live  : 4001
#   IB TWS live      : 7496   ← current default (set in config.py)
# IBKR_PORT=7496

# ══════════════════════════════════════════════════════════════════════════════
# DECIFER RUNTIME MODE — node identity (REQUIRED — set this first)
# ══════════════════════════════════════════════════════════════════════════════
#
# Each Decifer node must declare its runtime mode. This determines whether
# execution is permitted, what customer output is exposed, and how guardrails fire.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  MAC PAPER EXECUTION NODE (DUP481326)                                   │
# │  Set these in .env on the Mac running the paper bot.                    │
# │                                                                         │
# │  DECIFER_RUNTIME_MODE=paper_execution                                   │
# │  DECIFER_EXECUTION_ENABLED=true                                         │
# │  DECIFER_CUSTOMER_OUTPUT_MODE=false                                     │
# │  DECIFER_MOBILE_READ_ONLY=true                                          │
# │  DECIFER_DASHBOARD_CONTROL_ENABLED=false                                │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  DIGITALOCEAN INTELLIGENCE CLOUD NODE                                   │
# │  Set these via DigitalOcean App Platform env vars or DO Secrets.        │
# │  NEVER set DECIFER_EXECUTION_ENABLED=true on this node.                 │
# │                                                                         │
# │  DECIFER_RUNTIME_MODE=intelligence_cloud                                │
# │  DECIFER_EXECUTION_ENABLED=false                                        │
# │  DECIFER_CUSTOMER_OUTPUT_MODE=true                                      │
# │  DECIFER_MOBILE_READ_ONLY=true                                          │
# │  DECIFER_DASHBOARD_CONTROL_ENABLED=false                                │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  LOCAL DEVELOPMENT (default when DECIFER_RUNTIME_MODE is unset)         │
# │  Execution is NOT implied. Switch to paper_execution to run the bot.    │
# │                                                                         │
# │  DECIFER_RUNTIME_MODE=local_dev    ← default                            │
# │  DECIFER_EXECUTION_ENABLED=false   ← default                            │
# └─────────────────────────────────────────────────────────────────────────┘

# Active runtime mode for this node. See descriptions above.
# Valid values: local_dev | intelligence_cloud | paper_execution | full_trading
DECIFER_RUNTIME_MODE=local_dev

# Set to true ONLY on paper_execution or full_trading nodes.
# NEVER set true on intelligence_cloud (DigitalOcean).
DECIFER_EXECUTION_ENABLED=false

# Set to true on the intelligence cloud node to enable customer-facing output.
DECIFER_CUSTOMER_OUTPUT_MODE=false

# Mobile API is always read-only. Leave true.
DECIFER_MOBILE_READ_ONLY=true

# Dashboard execution controls (pause/resume/kill). Leave false unless
# running the operational dashboard with explicit Amit approval.
DECIFER_DASHBOARD_CONTROL_ENABLED=false

# Intelligence API CORS origin (DigitalOcean node only).
# Set to your frontend domain in production; * for development.
# INTELLIGENCE_API_CORS_ORIGIN=https://app.decifertrading.com

# ══════════════════════════════════════════════════════════════════════════════
# OPERATIONAL RUNTIME BEHAVIOUR
# ══════════════════════════════════════════════════════════════════════════════

# Handoff publisher publication mode.
#   validation_only       — manifest published with handoff_enabled=false (safe default)
#   controlled_activation — live handoff enabled (requires Amit approval)
# HANDOFF_PUBLISHER_MODE=validation_only

# Handoff publisher loop cadence in seconds (default: 900 = 15 minutes).
# Shorter = more frequent universe refreshes; do not go below 300.
# HANDOFF_PUBLISHER_INTERVAL_SECONDS=900

# Dashboard HTTP port (default: 8080).
# PORT=8080

# Dashboard refresh interval in milliseconds (default: 30000 = 30s).
# REFRESH_INTERVAL_MS=30000

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — rarely needed
# ══════════════════════════════════════════════════════════════════════════════

# Override auto-detected repo root. config.py detects via __file__; only
# set this if the auto-detection fails in an unusual deployment layout.
# DECIFER_REPO_PATH=/opt/decifer

# IBKR Flex Web Service (optional — used for equity history backfill only).
# Not required for normal operation.
# IBKR_FLEX_TOKEN=
# IBKR_FLEX_QUERY_ID=
# IBKR_FLEX_TRADES_QUERY_ID=

# Additional IBKR account slots (reserved for future live trading).
# Do not populate unless live trading has been approved.
# IBKR_LIVE_1_ACCOUNT=
# IBKR_LIVE_2_ACCOUNT=
