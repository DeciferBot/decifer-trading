#!/usr/bin/env bash
# Pre-push hook: type-check mobile/ if any mobile files are in the push.
# Catches broken imports (missing exports, wrong paths) before CI sees them.
# Stored in .githooks/ so it's committed and auto-installed by setup.sh.

REPO_ROOT="$(git rev-parse --show-toplevel)"
MOBILE_DIR="$REPO_ROOT/mobile"

MOBILE_CHANGED=0
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_sha"
  else
    RANGE="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$RANGE" 2>/dev/null | grep -q "^mobile/"; then
    MOBILE_CHANGED=1
    break
  fi
done

if [ "$MOBILE_CHANGED" -eq 0 ]; then
  exit 0
fi

echo "→ mobile/ files changed — running TypeScript check..."

cd "$MOBILE_DIR" || exit 1

npx tsc --noEmit 2>&1
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  echo ""
  echo "✗ TypeScript check FAILED — push blocked."
  echo "  Fix the errors above, then push again."
  exit 1
fi

echo "✓ TypeScript check passed."
exit 0
