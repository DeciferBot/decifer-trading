#!/usr/bin/env bash
# Pre-commit hook — reserved for linting, tests, or other pre-commit checks.
#
# Version bumping is intentionally NOT done here.
# It is handled entirely by .githooks/commit-msg, which reads the commit type
# and applies the correct bump (feat → MINOR, fix/chore/etc → PATCH, feat! → MAJOR).
# Bumping PATCH here and staging version.py caused commit-msg to exit early
# (it skips when version.py is already staged), so feat commits were silently
# downgraded to PATCH. Removing this logic restores correct semver behaviour.

exit 0
