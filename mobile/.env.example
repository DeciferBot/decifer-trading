# Customer Intelligence API — required for the customer Market Map surface (/customer route)
# Points to the DigitalOcean Intelligence API (public, read-only, GET-only)
NEXT_PUBLIC_INTELLIGENCE_API_URL=https://intelligence.decifertrading.com

# Operator-only: bot API URL (private, not for customer-facing routes)
# NEXT_PUBLIC_BOT_API_URL=http://<bot-host>:8080

# Server-side only (never exposed to browser)
# FMP_API_KEY=<your-fmp-api-key>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>  ← required for Ask Decifer chat
