<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.decifer.universe-promoter-preopen.plist
  Classification: documentation only / deployment template

  Standalone launchd daemon for the universe promoter pre-open run.

  Worker: universe_promoter_worker
  Schedule: Monday–Friday at 08:00 local time (pre-NYSE open).
  Uses prior-session bar data from Alpaca — works regardless of whether
  the market is open. No broker writes. No order placement.

  INSTALLATION:
    cp deployment/com.decifer.universe-promoter-preopen.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.decifer.universe-promoter-preopen.plist

  EVIDENCE:
    Heartbeat: data/heartbeats/universe_promoter_worker.json
    Stdout:    /tmp/decifer-universe-promoter-preopen.log
    Stderr:    /tmp/decifer-universe-promoter-preopen.err

  NOTE: Both promoter plists (EOD + pre-open) share the same heartbeat file.
  The last-run timestamp reflects whichever fired most recently.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.decifer.universe-promoter-preopen</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/python3.11</string>
    <string>universe_promoter.py</string>
    <string>--run-once</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/amitchopra/Desktop/decifer trading</string>

  <!-- 08:00 Monday–Friday -->
  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Weekday</key><integer>1</integer>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>0</integer>
    </dict>
    <dict>
      <key>Weekday</key><integer>2</integer>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>0</integer>
    </dict>
    <dict>
      <key>Weekday</key><integer>3</integer>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>0</integer>
    </dict>
    <dict>
      <key>Weekday</key><integer>4</integer>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>0</integer>
    </dict>
    <dict>
      <key>Weekday</key><integer>5</integer>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>0</integer>
    </dict>
  </array>

  <key>StandardOutPath</key>
  <string>/tmp/decifer-universe-promoter-preopen.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/decifer-universe-promoter-preopen.err</string>

  <key>KeepAlive</key>
  <false/>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
