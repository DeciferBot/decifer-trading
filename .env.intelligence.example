# .env.intelligence.example
#
# Minimal .env template for the Decifer Intelligence Cloud node (DigitalOcean).
#
# Runtime layer:    deployment/config
# Imported at runtime: No (template only — copy to .env on the droplet)
# Affects execution:   No
# Intelligence cloud:  Yes — this file is FOR the DO intelligence node
# Cloud cost/impact:   None (template, no values)
#
# This file contains ONLY the env vars required by the intelligence cloud.
# It does NOT contain IBKR keys, account identifiers, or execution-node vars.
# The full .env.example (repo root) is for the Mac execution node.
#
# Usage (DigitalOcean droplet):
#   cp .env.intelligence.example /opt/decifer/.env
#   # Fill in each <key> value — never commit the filled .env
#
# Alternative: set these as DigitalOcean App Platform secrets or
#   inject via Docker --env-file flag.
#
# Required keys: 7 (no IBKR keys required on intelligence cloud)
# Forbidden keys: IBKR_* — do NOT set any IBKR variable on this node.

# ── Runtime mode (hardcoded — do not change on intelligence cloud) ─────────────
# intelligence_cloud is the only valid value here.
# DECIFER_RUNTIME_MODE=intelligence_cloud means assert_execution_allowed()
# raises ExecutionBlockedError unconditionally, regardless of any other var.
DECIFER_RUNTIME_MODE=intelligence_cloud

# NEVER set to true on intelligence cloud — execution is unconditionally blocked
# by DECIFER_RUNTIME_MODE regardless, but this makes intent explicit.
DECIFER_EXECUTION_ENABLED=false

# Enable customer-facing SaaS output (required for /api/market-now to serve payload)
DECIFER_CUSTOMER_OUTPUT_MODE=true

# Mobile routes are read-only (default, leave as true)
DECIFER_MOBILE_READ_ONLY=true

# Dashboard execution controls are disabled (no dashboard on intelligence cloud)
DECIFER_DASHBOARD_CONTROL_ENABLED=false

# ── LLM / Apex ────────────────────────────────────────────────────────────────
# Required for run_intelligence_pipeline.py (Apex synthesis calls)
ANTHROPIC_API_KEY=

# ── Market data — Alpaca (read-only, no order placement) ─────────────────────
# Alpaca is used for price feeds in live_driver_resolver.py.
# Use the DATA URL (not the paper-api URL used by the execution bot).
# The intelligence cloud never places orders — read-only market data only.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://data.alpaca.markets

# ── Market data — FMP ────────────────────────────────────────────────────────
# Financial Modeling Prep: fundamentals, analyst actions, earnings calendar.
# Read-only. No order placement.
FMP_API_KEY=

# ── Market data — Alpha Vantage (macroeconomic indicators) ───────────────────
ALPHA_VANTAGE_KEY=

# ── Market data — FRED (Federal Reserve economic data) ───────────────────────
FRED_API_KEY=

# ── Intelligence API — CORS ───────────────────────────────────────────────────
# Restrict CORS to your frontend domain in production.
# Default (*) is acceptable while behind Cloudflare Access.
# INTELLIGENCE_API_CORS_ORIGIN=https://app.decifertrading.com

# ────────────────────────────────────────────────────────────────────────────
# ⛔ KEYS THAT MUST NOT APPEAR ON THIS NODE
# ────────────────────────────────────────────────────────────────────────────
# Do not set any of the following on the DigitalOcean intelligence cloud.
# The intelligence cloud has no IBKR connection and no execution capability.
#
#   IBKR_ACTIVE_ACCOUNT  — execution node only (Mac)
#   IBKR_PAPER_ACCOUNT   — execution node only (Mac)
#   IBKR_HOST            — execution node only (Mac)
#   IBKR_PORT            — execution node only (Mac)
#   IBKR_FLEX_TOKEN      — execution node only (Mac)
