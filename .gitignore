data/signals_typed.jsonl
data/audit_log.jsonl
data/sec_tickers.json
data/*.bak
data/raw/
data/features/

# Apex debug/audit logs — append-only, grow unboundedly, not business-critical data
# Rotation is managed in code (utils/log_rotation.py). Kept local, not committed.
data/apex_shadow_log.jsonl
data/apex_shadow_log.jsonl.*
data/apex_decision_audit.jsonl
data/apex_decision_audit.jsonl.*
data/apex_prompt_snapshot.jsonl
data/apex_prompt_snapshot.jsonl.*
data/apex_response_snapshot.jsonl
data/apex_response_snapshot.jsonl.*

# Handoff publisher failure records — diagnostic output, never sentinel inputs
data/live/.fail_*.json

