# Environment & secrets
.env
.env.local
.env.production
*.pem
*.key
.mcp.json

# Data files (large or regenerable — small critical files are tracked)
data/*.csv
data/*.parquet
data/historical/

# Large / regenerable data files that must never be committed
data/signals_log.jsonl
data/signals_log.jsonl.*
# ML evidence ledgers — append-only, grow unboundedly; summaries (*.json) are committed
data/ml/ml_observations.jsonl
data/ml/ml_observations.jsonl.*
data/ml/canonical_learning_dataset.jsonl
data/ml/canonical_learning_dataset.jsonl.*
